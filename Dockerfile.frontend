# Build stage
FROM node:20-alpine AS builder
WORKDIR /app
COPY stratify-react/package.json stratify-react/package-lock.json ./
RUN npm ci
COPY stratify-react/ .
# .env.production is written by deploy.sh before this build runs
RUN npm run build

# Serve stage
FROM nginx:1.25-alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 8080
CMD ["nginx", "-g", "daemon off;"]
